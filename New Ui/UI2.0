        Elevated = Color3.fromRGB(34, 35, 41),
        ElevatedHi = Color3.fromRGB(44, 45, 52),
        Stroke = Color3.fromRGB(58, 62, 79),
        Text = Color3.fromRGB(245, 245, 247),
        SubText = Color3.fromRGB(177, 180, 190),
        Accent = Color3.fromRGB(100, 121, 255),
